// SQLite no soporta enum nativo en Prisma: los campos tipo-enum se guardan
// como String y se validan con Zod en la capa de app. Al migrar a Postgres,
// convertir esos campos a `enum` real y los campos JSON-como-String
// (metadata, measurements, generatedPlan) a `Json` nativo.

generator client {
  provider      = "prisma-client-js"
  // "native" cubre el entorno de desarrollo (Windows/Mac/Linux glibc);
  // linux-musl-openssl-3.0.x es el motor que corre dentro de node:*-alpine
  // (Docker). Sin esto, "prisma generate" puede no empaquetar el binario
  // correcto para el contenedor y el motor falla al cargar en runtime
  // (aunque el build haya sido exitoso).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks               Task[]           @relation("TaskOwner")
  assignedTasks       Task[]           @relation("TaskAssignee")
  transactions        Transaction[]
  categories          Category[]
  groupsCreated       Group[]          @relation("GroupCreator")
  groupMembers        GroupMember[]
  notifications       Notification[]
  fitnessLogs         FitnessLog[]
  dietPlans           DietPlan[]
  invitesSent         Invite[]         @relation("InviteSender")
  workSessions        WorkSession[]
  projectComments     ProjectComment[]
  deliverablesCreated Deliverable[]    @relation("DeliverableCreator")
  budgets             Budget[]
  savingsGoals        SavingsGoal[]
  recurringTxns       RecurringTransaction[]
}

model Invite {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy String
  sender    Profile  @relation("InviteSender", fields: [invitedBy], references: [id])
  status    String   @default("pending") // pending|accepted|expired
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([groupId])
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  user        Profile   @relation("TaskOwner", fields: [userId], references: [id])
  assigneeId  String?
  assignee    Profile?  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      String    @default("pending") // pending|in_progress|done
  priority    String    @default("medium") // low|medium|high
  dueDate     DateTime?
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([assigneeId])
  @@index([projectId])
}

model Category {
  id     String  @id @default(cuid())
  userId String
  user   Profile @relation(fields: [userId], references: [id])
  name   String
  type   String // income|expense

  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
}

model Transaction {
  id         String    @id @default(cuid())
  userId     String
  user       Profile   @relation(fields: [userId], references: [id])
  type       String // income|expense
  amount     Float
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date       DateTime
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([date])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  createdBy String
  creator   Profile  @relation("GroupCreator", fields: [createdBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  GroupMember[]
  projects Project[]
  invites  Invite[]
}

model GroupMember {
  id      String  @id @default(cuid())
  groupId String
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    Profile @relation(fields: [userId], references: [id])
  role    String  @default("member") // owner|admin|member

  @@unique([groupId, userId])
  @@index([userId])
}

model Project {
  id          String    @id @default(cuid())
  groupId     String
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      String    @default("active") // active|paused|done
  type        String    @default("ongoing") // ongoing|dated
  progress    Int       @default(0) // 0-100
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tasks        Task[]
  deliverables Deliverable[]
  workSessions WorkSession[]
  comments     ProjectComment[]

  @@index([groupId])
}

model Deliverable {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String    @default("pending") // pending|delivered
  dueDate     DateTime?
  deliveredAt DateTime?
  createdBy   String
  creator     Profile   @relation("DeliverableCreator", fields: [createdBy], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}

model WorkSession {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile   @relation(fields: [userId], references: [id])
  startedAt DateTime
  endedAt   DateTime? // null = sesión en curso (timer corriendo)
  note      String?
  createdAt DateTime  @default(now())

  @@index([projectId])
  @@index([userId])
}

model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile  @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([projectId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      Profile  @relation(fields: [userId], references: [id])
  type      String // task_due|task_overdue|expense_high|goal_reached|project_update|routine_reminder|task_assigned|comment_added|deliverable_due
  message   String
  read      Boolean  @default(false)
  metadata  String? // JSON.stringify de contexto extra (entityId, etc.)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

model FitnessLog {
  id                String   @id @default(cuid())
  userId            String
  user              Profile  @relation(fields: [userId], references: [id])
  date              DateTime
  weightKg          Float?
  measurements      String? // JSON: {chest, waist, hips, ...}
  routineCompliance Int? // 0-100 %
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

model DietPlan {
  id             String   @id @default(cuid())
  userId         String
  user           Profile  @relation(fields: [userId], references: [id])
  ageYears       Int
  sex            String // male|female
  heightCm       Float
  weightKg       Float
  activityLevel  String // sedentary|light|moderate|active|very_active
  goal           String // lose|maintain|gain
  bmr            Float // resultado Mifflin-St Jeor
  tdee           Float // gasto total diario estimado
  targetCalories Float
  generatedPlan  String? // JSON con macros sugeridos (placeholder)
  createdAt      DateTime @default(now())

  @@index([userId])
}

// Presupuesto mensual por categoría (o general si categoryId es null).
// El gasto se calcula contra las transacciones del mes en curso.
model Budget {
  id         String    @id @default(cuid())
  userId     String
  user       Profile   @relation(fields: [userId], references: [id])
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount     Float // límite mensual
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
}

// Meta de ahorro con aportes acumulados. Al alcanzar el objetivo se dispara
// la notificación goal_reached (una sola vez, marcada con reachedAt).
model SavingsGoal {
  id            String    @id @default(cuid())
  userId        String
  user          Profile   @relation(fields: [userId], references: [id])
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  dueDate       DateTime?
  reachedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

// Plantilla de transacción recurrente. Un cron materializa una Transaction
// real cada vez que nextRun llega, y avanza nextRun según el intervalo.
model RecurringTransaction {
  id         String   @id @default(cuid())
  userId     String
  user       Profile  @relation(fields: [userId], references: [id])
  type       String // income|expense
  amount     Float
  categoryId String?
  note       String?
  interval   String // daily|weekly|monthly
  nextRun    DateTime
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([nextRun])
}
